# --- Required ---
ANTHROPIC_API_KEY=your_key_here

# Claude model. Default is the current Haiku — fast and inexpensive.
# Other valid choices: claude-sonnet-4-6, claude-opus-4-6
CHAT_MODEL=claude-haiku-4-5-20251001

# --- IT Ops API (replaces the old MCP demo) ---
# Internal token shared between the backend and the ops API.
# Any non-empty value works for local dev. Rotate before deploy.
IT_OPS_API_TOKEN=dev-local-only-token
IT_OPS_API_URL=http://localhost:8001
IT_OPS_DB_PATH=./services/it_ops_api/it_ops.db

# --- RAG / vector store ---
CHROMA_DB_PATH=./chroma_db
KB_DIR=./backend/data/kb
RAG_DISTANCE_THRESHOLD=0.85

# --- App ---
ENV=dev
ALLOWED_ORIGINS=http://localhost:5173
ENABLE_DEBUG_ENDPOINTS=true
